# Notion Integration
# Create an internal integration at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Copy the database ID from the URL when the Tasks database is open in Notion
# e.g. https://notion.so/workspacename/<DATABASE_ID>?v=...
NOTION_TASKS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Signing secret shown after creating a webhook in Notion's developer settings.
# Leave blank during local testing to skip signature verification.
NOTION_WEBHOOK_SECRET=your_webhook_signing_secret_here

# Telegram Bot
# Get token from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Group chat ID. Add @userinfobot to your group and send any message to get it.
# Group IDs are negative numbers, e.g. -1001234567890
TELEGRAM_CHAT_ID=-1001234567890

# HTTP server port (optional, defaults to 3000)
PORT=3000

# Public domain for Telegram webhook registration (set automatically by Railway).
# On Railway this is the value shown in Settings → Networking → Public Domain,
# WITHOUT the https:// prefix, e.g. taskr-production.up.railway.app
# Locally you can use ngrok: ngrok http 3000 → set this to the ngrok subdomain.
RAILWAY_PUBLIC_DOMAIN=
